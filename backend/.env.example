PORT=5000
MONGODB_URI=mongodb://localhost:27017/rentbike
JWT_SECRET=change-this-to-a-random-secret-string

# Cloudinary (get from https://cloudinary.com — free tier: 25GB storage)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# SSLCommerz (get from https://sandbox.sslcommerz.com — sandbox for testing)
SSLCOMMERZ_STORE_ID=your-store-id
SSLCOMMERZ_STORE_PASS=your-store-password
SSLCOMMERZ_IS_LIVE=false

# URLs — update these for production
# Local: BACKEND_URL=http://localhost:5000, FRONTEND_URL=http://localhost:5173
# Production: BACKEND_URL=https://your-app.onrender.com, FRONTEND_URL=https://your-app.vercel.app
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173
